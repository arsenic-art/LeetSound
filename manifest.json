{
  "manifest_version": 3,
  "name": "LeetSound",
  "version": "1.0",
  "description": "Plays sounds based on LeetCode submission results.",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sounds/*.mp3"],
      "matches": ["https://leetcode.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
